# PostgreSQL
DB_USER=scribe_user
DB_PASSWORD=scribe_pass
DB_NAME=ai_scribe_db
DB_HOST=localhost
DB_PORT=5433

# Backend
PORT=3001
DATABASE_URL=postgresql://scribe_user:scribe_pass@localhost:5433/ai_scribe_db
CORS_ORIGIN=http://localhost:3000
UPLOAD_DIR=./uploads

# OpenAI (optional — set AI_MOCK_MODE=true to run without a key)
OPENAI_API_KEY=
AI_MOCK_MODE=true
OPENAI_MODEL=gpt-4o-mini
# Note: do not use # in .env values (it starts a comment)
WHISPER_MODEL=whisper-1

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api
# Server-side only (Docker: use http://backend:3001/api)
API_INTERNAL_URL=http://localhost:3001/api
